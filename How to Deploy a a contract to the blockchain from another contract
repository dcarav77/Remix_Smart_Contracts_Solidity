        SimpleStorage simpleStorage = new SimpleStorage();
//Generate a contract of simplestorage type. Create an object of type "SimpleStorage". Name it LOWERcase simplestorage. This is NEW simple storage contract
        simpleStorageArray.push(simpleStorage); 
//
    }
}

